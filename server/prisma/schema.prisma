generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  SCAN_AGENT
  REPORT_AGENT
}

enum ParticipantType {
  PARTICIPANT
  COACH
  ORGANIZER
  GUEST
}

enum ExpectedPresence {
  MONDAY
  TUESDAY
  BOTH_DAYS
  UNKNOWN
}

enum MovementType {
  ENTRY
  EXIT
}

enum ScanMethod {
  QR_SCAN
  MANUAL_BADGE_CODE
  MANUAL_SEARCH
  ADMIN_CORRECTION
}

enum AlertActionType {
  CONTACTED
  AUTHORIZED_EXIT
  RETURN_CONFIRMED
  ESCALATED
}

enum BadgeEmailStatus {
  SENT
  FAILED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SCAN_AGENT)
  isActive     Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passages       Passage[]      @relation("ScannedBy")
  cancellations  Passage[]      @relation("CancelledBy")
  alertActions   AlertAction[]
  importBatches  ImportBatch[]
  auditLogs      AuditLog[]
}

model Participant {
  id               String           @id @default(cuid())
  participantType  ParticipantType  @default(PARTICIPANT)
  sourceCategory   String?
  firstName        String?
  lastName         String?
  fullName         String
  school           String?
  organization     String?
  groupName        String?
  teamName         String?
  roleLabel        String?
  competitionMode  String?
  memberCount      Int?
  competitionLevel String?
  competitionCategories String?
  email            String?
  phone            String?
  gender           String?
  city             String?
  statusLabel      String?
  badgeCode        String           @unique
  qrToken          String           @unique
  photoPath        String?
  hasSmartphone    Boolean?
  expectedPresence ExpectedPresence @default(UNKNOWN)
  isLastMinute     Boolean          @default(false)
  isActive         Boolean          @default(true)
  sourceReference  String?
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  passages     Passage[]
  alertActions AlertAction[]
  badgeEmailDelivery BadgeEmailDelivery?

  @@index([fullName])
  @@index([phone])
  @@index([email])
  @@index([groupName])
  @@index([teamName])
}

model Passage {
  id                 String       @id @default(cuid())
  participantId      String
  participant        Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  movementType       MovementType
  scannedAt          DateTime     @default(now())
  scannedByUserId    String
  scannedBy          User         @relation("ScannedBy", fields: [scannedByUserId], references: [id])
  scanMethod         ScanMethod
  gateName           String?
  deviceName         String?
  note               String?      @db.Text
  isCancelled        Boolean      @default(false)
  cancelledAt        DateTime?
  cancelledByUserId  String?
  cancelledBy        User?        @relation("CancelledBy", fields: [cancelledByUserId], references: [id])
  cancelReason       String?
  createdAt          DateTime     @default(now())

  @@index([participantId, scannedAt])
  @@index([scannedAt])
}

model AlertAction {
  id              String          @id @default(cuid())
  participantId   String
  participant     Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)
  actionType      AlertActionType
  note            String?         @db.Text
  createdByUserId String
  createdBy       User            @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime        @default(now())
}

model BadgeTemplate {
  id                  String   @id @default(cuid())
  name                String
  templatePath        String?
  logoPrimaryPath     String?
  logoSecondaryPath   String?
  logoPartnerPath     String?
  backgroundPath      String?
  isDefault           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Setting {
  id                          String   @id @default(cuid())
  eventName                   String
  publicBaseUrl               String
  exitWarningMinutes          Int      @default(30)
  exitCriticalMinutes         Int      @default(60)
  duplicateScanWindowSeconds  Int      @default(30)
  allowSelfPhotoUpload        Boolean  @default(true)
  requirePhotoValidation      Boolean  @default(false)
  bootstrapCompleted          Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model ImportBatch {
  id               String   @id @default(cuid())
  fileName         String
  sourceCategory   String
  importedByUserId String
  importedBy       User     @relation(fields: [importedByUserId], references: [id])
  totalRows        Int
  importedRows     Int
  skippedRows      Int
  errorRows        Int
  createdAt        DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  detailsJson Json?
  createdAt   DateTime @default(now())
}

model BadgeEmailDelivery {
  id             String           @id @default(cuid())
  participantId  String           @unique
  participant    Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  recipientEmail String
  status         BadgeEmailStatus
  messageId      String?
  errorMessage   String?          @db.Text
  sentAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([sentAt])
}
